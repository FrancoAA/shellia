# =============================================================================
# Entrypoint
# =============================================================================

# Check dependencies
require_cmd jq
require_cmd curl

# Apply default theme early (before init/help which may use colors)
apply_theme "default"

# Init command (before version/help since it doesn't need config)
if [[ "${1:-}" == "init" ]]; then
    shellia_init
    exit 0
fi

# Profile subcommands (don't need full config validation)
if [[ "${1:-}" == "profiles" ]]; then
    load_config
    apply_theme "${SHELLIA_THEME:-default}"
    list_profiles
    exit 0
fi

if [[ "${1:-}" == "profile" ]]; then
    case "${2:-}" in
        add)
            if [[ -z "${3:-}" ]]; then
                die "Usage: shellia profile add <name>"
            fi
            load_config
            apply_theme "${SHELLIA_THEME:-default}"
            add_profile "$3"
            exit $?
            ;;
        remove)
            if [[ -z "${3:-}" ]]; then
                die "Usage: shellia profile remove <name>"
            fi
            load_config
            apply_theme "${SHELLIA_THEME:-default}"
            remove_profile "$3"
            exit $?
            ;;
        *)
            die "Usage: shellia profile add|remove <name>"
            ;;
    esac
fi

# Version
if [[ "${1:-}" == "--version" ]]; then
    echo "shellia v${SHELLIA_VERSION}"
    exit 0
fi

# Help
if [[ "${1:-}" == "--help" || "${1:-}" == "-h" ]]; then
    echo "Usage: shellia [OPTIONS] [PROMPT]"
    echo ""
    echo "A terminal agent that helps you execute and automate tasks from the console."
    echo ""
    echo "Options:"
    echo "  init                      Run setup wizard"
    echo "  profiles                  List all profiles"
    echo "  profile add <name>        Add or update a profile"
    echo "  profile remove <name>     Remove a profile"
    echo "  --profile <name>          Use a specific profile"
    echo "  --dry-run                 Show command without executing"
    echo "  --debug                   Show debug information"
    echo "  --help, -h                Show this help message"
    echo "  --version                 Print version"
    echo ""
    echo "Modes:"
    echo "  shellia find large files  Single command mode (no quotes needed)"
    echo "  shellia                   REPL mode (interactive)"
    echo "  cmd | shellia explain     Pipe mode (analyze input)"
    exit 0
fi

# --- Pipe detection ---

PIPED_INPUT=""
if [[ ! -t 0 ]]; then
    PIPED_INPUT=$(cat)
fi

# --- Flag parsing ---

SHELLIA_DRY_RUN=false
PROMPT_ARGS=()

while [[ $# -gt 0 ]]; do
    case "$1" in
        --dry-run)
            SHELLIA_DRY_RUN=true
            shift
            ;;
        --debug)
            SHELLIA_DEBUG=true
            shift
            ;;
        --profile)
            if [[ -z "${2:-}" ]]; then
                die "Usage: --profile <name>"
            fi
            SHELLIA_PROFILE="$2"
            shift 2
            ;;
        *)
            PROMPT_ARGS+=("$1")
            shift
            ;;
    esac
done

# Export dry-run flag for tools to check
export SHELLIA_DRY_RUN

# Join prompt arguments into a single string
PROMPT="${PROMPT_ARGS[*]:-}"

# --- Build user prompt with piped content ---

if [[ -n "$PIPED_INPUT" && -n "$PROMPT" ]]; then
    # Single prompt mode with piped input — combine them
    PROMPT="${PROMPT}

The following is the content piped as input for context:
${PIPED_INPUT}"
fi
# When PIPED_INPUT is set but PROMPT is empty, REPL mode will
# include the piped input as context for the first prompt.

# --- Dispatch ---

if [[ -n "$PROMPT" ]]; then
    # Single prompt mode
    load_config
    validate_config
    apply_theme "${SHELLIA_THEME:-default}"
    load_dangerous_commands
    load_tools
    debug_log "mode" "single-prompt"
    debug_log "prompt" "$PROMPT"
    [[ -n "$PIPED_INPUT" ]] && debug_log "pipe" "piped input included ($(echo "$PIPED_INPUT" | wc -c | tr -d ' ') bytes)"
    mode="single-prompt"
    [[ -n "$PIPED_INPUT" ]] && mode="pipe"
    system_prompt=$(build_system_prompt "$mode")
    messages=$(build_single_messages "$system_prompt" "$PROMPT")
    tools=$(build_tools_array)
    spinner_start "Thinking..."
    response=$(api_chat_loop "$messages" "$tools")
    api_exit=$?
    spinner_stop
    [[ $api_exit -ne 0 ]] && exit 1
    # Display the final text response if any
    if [[ -n "$response" ]]; then
        echo "$response"
    fi
else
    # REPL mode
    load_config
    validate_config
    apply_theme "${SHELLIA_THEME:-default}"
    load_dangerous_commands
    load_tools
    repl_start
fi
