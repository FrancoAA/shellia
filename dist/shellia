# Apply a theme by name
apply_theme() {
    local theme="${1:-default}"

    # Skip if no terminal
    [[ -t 1 ]] || return 0

    case "$theme" in
        default)
            theme_default
            ;;
        ocean)
            theme_ocean
            ;;
        forest)
            theme_forest
            ;;
        sunset)
            theme_sunset
            ;;
        minimal)
            theme_minimal
