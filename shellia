#!/usr/bin/env bash
set -euo pipefail

# Resolve script directory for sourcing lib files
SHELLIA_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# Source library files
source "${SHELLIA_DIR}/lib/utils.sh"
source "${SHELLIA_DIR}/lib/config.sh"
source "${SHELLIA_DIR}/lib/profiles.sh"
source "${SHELLIA_DIR}/lib/prompt.sh"
source "${SHELLIA_DIR}/lib/api.sh"
source "${SHELLIA_DIR}/lib/executor.sh"
source "${SHELLIA_DIR}/lib/themes.sh"
source "${SHELLIA_DIR}/lib/tools.sh"
source "${SHELLIA_DIR}/lib/repl.sh"
source "${SHELLIA_DIR}/lib/plugins.sh"

# Check dependencies
check_dependencies jq curl

# Apply default theme early (before init/help which may use colors)
apply_theme "default"

# --- Meta commands (hardcoded, not pluggable) ---

if [[ "${1:-}" == "--version" ]]; then
    echo "shellia v${SHELLIA_VERSION}"
    exit 0
fi

if [[ "${1:-}" == "--help" || "${1:-}" == "-h" ]]; then
    # Only load bundled plugins for help output, so user plugin files
    # (from ~/.config/shellia/plugins) do not run during metadata-only mode.
    load_builtin_plugins
    generate_help
    exit 0
fi

# Load all plugins for normal command execution paths
load_plugins

# --- Pipe detection ---

PIPED_INPUT=""
if [[ ! -t 0 ]]; then
    PIPED_INPUT=$(cat)
fi

# --- Flag parsing (plugin-provided, must happen before subcommand dispatch) ---

SHELLIA_DRY_RUN="${SHELLIA_DRY_RUN:-false}"
SHELLIA_WEB_MODE="${SHELLIA_WEB_MODE:-false}"

parse_cli_flags "$@"

# Export flags for tools to check
export SHELLIA_DRY_RUN
export SHELLIA_WEB_MODE

# --- CLI subcommand dispatch (plugin-provided) ---
# After flag parsing, PROMPT_ARGS contains non-flag arguments.
# Check if the first one is a known subcommand.

if [[ ${#PROMPT_ARGS[@]} -gt 0 ]]; then
    local_cmd="${PROMPT_ARGS[0]}"
    local_args=("${PROMPT_ARGS[@]:1}")
    if dispatch_cli_command "$local_cmd" "${local_args[@]+"${local_args[@]}"}"; then
        exit $?
    fi
fi

# Join prompt arguments into a single string
PROMPT="${PROMPT_ARGS[*]:-}"

# --- Build user prompt with piped content ---

if [[ -n "$PIPED_INPUT" && -n "$PROMPT" ]]; then
    # Single prompt mode with piped input — combine them
    PROMPT="${PROMPT}

The following is the content piped as input for context:
${PIPED_INPUT}"
fi
# When PIPED_INPUT is set but PROMPT is empty, REPL mode will
# include the piped input as context for the first prompt.

# --- Dispatch ---

# Validate a web session ID to avoid path traversal in session files.
is_valid_session_id() {
    local session_id="$1"

    [[ -n "$session_id" ]] &&
        [[ ${#session_id} -le 128 ]] &&
        [[ "$session_id" =~ ^[A-Za-z0-9._-]+$ ]]
}

generate_session_id() {
    if command -v uuidgen >/dev/null 2>&1; then
        uuidgen | tr -d '\n'
        return
    fi

    printf '%s-%s' "$(date +%s%N)" "$RANDOM"
}

if [[ "$SHELLIA_WEB_MODE" == "true" && -n "$PROMPT" ]]; then
    # Web mode: session-based conversation with structured event output
    load_config
    validate_config
    apply_theme "${SHELLIA_THEME:-default}"
    load_tools
    fire_hook "init"

    debug_log "mode" "web"
    debug_log "prompt" "$PROMPT"

    # Session management
    sessions_dir="${SHELLIA_WEB_SESSIONS_DIR:-/tmp/shellia_web_sessions}"
    session_id="${SHELLIA_WEB_SESSION_ID:-}"
    if ! is_valid_session_id "$session_id"; then
        [[ -n "$session_id" ]] && debug_log "security" "invalid session id ignored: ${session_id}"
        session_id=$(generate_session_id)
    fi
    session_file="${sessions_dir}/${session_id}.json"
    mkdir -p "$sessions_dir"

    # Initialize session file if it doesn't exist
    if [[ ! -f "$session_file" ]]; then
        echo '[]' > "$session_file"
    fi

    system_prompt=$(build_system_prompt "web")
    SHELLIA_LOADED_SKILL_CONTENT=""
    SHELLIA_LOADED_SKILL_NAME=""
    tools=$(build_tools_array)

    # Build messages with session history
    messages=$(build_conversation_messages "$system_prompt" "$session_file" "$PROMPT")

    # Emit thinking event
    echo '__SHELLIA_EVENT__:{"type":"status","status":"thinking"}'

    # Call API with tool loop
    response=$(api_chat_loop "$messages" "$tools")
    api_exit=$?

    if [[ $api_exit -ne 0 ]]; then
        echo '__SHELLIA_EVENT__:{"type":"error","message":"API call failed"}'
        fire_hook "shutdown"
        exit 1
    fi

    # Update session history
    local updated
    updated=$(jq \
        --arg usr "$PROMPT" \
        --arg asst "${response:-}" \
        '. + [{"role": "user", "content": $usr}, {"role": "assistant", "content": $asst}]' \
        "$session_file")
    echo "$updated" > "$session_file"

    fire_hook "user_message" "$PROMPT"
    fire_hook "assistant_message" "$response"

    # Output the response text (server reads this as plain text lines)
    if [[ -n "$response" ]]; then
        echo "$response"
    fi

    fire_hook "shutdown"

elif [[ -n "$PROMPT" ]]; then
    # Single prompt mode
    load_config
    validate_config
    apply_theme "${SHELLIA_THEME:-default}"
    load_tools
    fire_hook "init"
    debug_log "mode" "single-prompt"
    debug_log "prompt" "$PROMPT"
    [[ -n "$PIPED_INPUT" ]] && debug_log "pipe" "piped input included ($(echo "$PIPED_INPUT" | wc -c | tr -d ' ') bytes)"
    mode="single-prompt"
    [[ -n "$PIPED_INPUT" ]] && mode="pipe"
    system_prompt=$(build_system_prompt "$mode")
    SHELLIA_LOADED_SKILL_CONTENT=""
    SHELLIA_LOADED_SKILL_NAME=""
    messages=$(build_single_messages "$system_prompt" "$PROMPT")
    tools=$(build_tools_array)
    spinner_start "Thinking..."
    response=$(api_chat_loop "$messages" "$tools")
    api_exit=$?
    spinner_stop
    [[ $api_exit -ne 0 ]] && { fire_hook "shutdown"; exit 1; }
    # Display the final text response if any
    if [[ -n "$response" ]]; then
        echo "$response"
    fi
    fire_hook "shutdown"
else
    # REPL mode
    load_config
    validate_config
    apply_theme "${SHELLIA_THEME:-default}"
    load_tools
    fire_hook "init"
    repl_start
    fire_hook "shutdown"
fi
